<main>
  <app-header></app-header>
  <section class="d-flex flex-column justify-content-center align-items-center" id="sectionHeader"
    style="height: 100vh; padding-right: var(--space5XL); padding-left: var(--space4XL);">
    <header class="container" style="max-width: 780px; top: calc(var(--spaceL) * -1); position:relative;">
      <div>
        <input placeholder="Digite o título">
        <h2 class="text-secondary" id="MyName" style="font-size: 1.375rem; margin: 0; letter-spacing: 0.1rem;" [textContent]="name"></h2>
        <h1 class="text-white title-with-line" id="HeaderTitle" style="margin-bottom: 0.5rem;">Back-End</h1>
        <h2 class="text-white d-flex justify-content-end title-with-line-developer" id="HeaderTitle">
          <span>Developer</span>
          <span class="line "></span>
        </h2>
      </div>
      <div class="d-flex justify-content-end">
        <p class="text-secondary" id="LanguagesHeader" style="font-size: 1.3rem; letter-spacing: 0.1rem;">Java | Spring
          Boot | MySQL</p>
      </div>
    </header>
    <div class="scroll-indicator mt-5" [class.hidden]="isScrolled" id="scrollIndicator">
      <div class="mouse">
        <div class="scroll"></div>
      </div>
    </div>
  </section>


<app-projects></app-projects>
<app-about-me></app-about-me>
<app-footer></app-footer>
</main>





















